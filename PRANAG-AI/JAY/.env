# LLM — install Ollama from https://ollama.ai then: ollama pull deepseek-r1:7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:7b
OPENAI_API_KEY=

# Vector Store — ChromaDB runs embedded by default (no server needed)
# For server mode: docker run -p 8000:8000 chromadb/chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=crop_traits
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Research APIs
SEMANTIC_SCHOLAR_KEY=https://www.semanticscholar.org/product/api
ARXIV_MAX_RESULTS=5

# Pipeline
MAX_RETRIES=3
SEARCH_TOP_K=10
MIN_CONFIDENCE=0.6
